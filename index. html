<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Garena Top Up</title>
    <style>
        body { 
            margin: 0; 
            height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            background: #1a1a1a; 
            font-family: sans-serif; 
        }
        .login-box { 
            background: rgba(255, 255, 255, 0.1); 
            backdrop-filter: blur(15px); 
            padding: 30px; 
            border-radius: 20px; 
            border: 1px solid rgba(255, 255, 255, 0.2); 
            width: 300px; 
            color: white; 
            text-align: center;
        }
        input { 
            width: 100%; 
            padding: 12px; 
            margin: 10px 0; 
            background: rgba(255, 255, 255, 0.1); 
            border: 1px solid rgba(255, 255, 255, 0.2); 
            border-radius: 10px; 
            color: white; 
            box-sizing: border-box;
        }
        .btn { 
            background: #d32f2f; 
            width: 100%; 
            padding: 12px; 
            border-radius: 10px; 
            color: white; 
            border: none; 
            margin-top: 20px; 
            cursor: pointer; 
            font-weight: bold;
        }
        .grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 10px; 
            margin-top: 15px;
        }
        .diamond-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 10px;
            color: white;
            border-radius: 10px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<div class="login-box">
    <h2>مركز الشحن</h2>
    <input type="text" placeholder="ID اللاعب">
    <div class="grid">
        <div class="diamond-btn">530 💎</div>
        <div class="diamond-btn">1080 💎</div>
        <div class="diamond-btn">2200 💎</div>
        <div class="diamond-btn">5600 💎</div>
    </div>
    <button class="btn" onclick="alert('خطأ في الاتصال بالسيرفر')">شراء الآن</button>
</div>

</body>
</html>
